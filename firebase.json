{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebase",
      ".claude",
      ".git",
      ".gradle",
      "CLAUDE.md",
      "코딩",
      "node_modules",
      "app",
      "build",
      "gradle",
      "gradlew",
      "gradlew.bat",
      "build.gradle",
      "settings.gradle",
      "gradle.properties",
      "**/*.apk",
      "**/*.aab",
      "**/*.idsig",
      "**/*.keystore",
      "**/*.exe",
      "**/*.bat",
      "**/*.sh",
      "**/*.jar",
      "twa-manifest.json",
      "manifest-checksum.txt",
      "feature-graphic.html",
      "store_icon.png"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  }
}
